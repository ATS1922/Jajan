<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
  <title>Aditya - Jajan Keuangan</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(145deg, #f9e7b3 0%, #f5d78c 100%);
      font-family: 'Segoe UI', 'Poppins', system-ui, -apple-system, sans-serif;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
      margin: 0;
      color: #4a3b1f;
    }

    .app-container {
      width: 100%;
      max-width: 480px;
      background: rgba(255, 251, 235, 0.85);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      background: #fffef2;
      border-radius: 48px;
      box-shadow: 0 30px 50px rgba(140, 100, 30, 0.25), 0 10px 20px rgba(0,0,0,0.1);
      padding: 28px 20px 32px;
      border: 2px solid #ffd78b;
      display: flex;
      flex-direction: column;
      gap: 22px;
    }

    /* Header */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: #ffb347;
      background: linear-gradient(135deg, #ff9f2f, #fb8c1e);
      padding: 16px 22px;
      border-radius: 100px;
      color: white;
      box-shadow: 0 8px 16px rgba(251, 140, 30, 0.35);
      margin-bottom: 6px;
    }

    .app-name {
      font-weight: 800;
      font-size: 1.9rem;
      letter-spacing: 1px;
      text-shadow: 0 3px 5px rgba(0,0,0,0.15);
      background: rgba(255,255,240,0.2);
      padding: 0 6px;
      border-radius: 20px;
      line-height: 1.2;
    }

    .saldo-box {
      background: white;
      border-radius: 40px;
      padding: 10px 18px;
      color: #b45f06;
      font-weight: 700;
      font-size: 1.3rem;
      box-shadow: inset 0 2px 6px rgba(0,0,0,0.05);
      display: flex;
      align-items: center;
      gap: 4px;
      background: #fffaee;
    }

    .saldo-box span {
      font-weight: 800;
      font-size: 1.6rem;
      margin-left: 4px;
    }

    /* Menu grid */
    .menu-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin: 6px 0 10px;
    }

    .menu-card {
      background: #ffffff;
      border-radius: 36px;
      padding: 16px 10px 12px;
      box-shadow: 0 12px 20px rgba(0,0,0,0.06), 0 4px 10px rgba(200, 140, 50, 0.2);
      transition: all 0.2s ease;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      border: 2px solid #ffe0a8;
      background: #fffdf3;
      cursor: pointer;
      user-select: none;
    }

    .menu-card:active {
      transform: scale(0.94);
      background: #fff2d8;
      border-color: #ffaa33;
      box-shadow: 0 6px 12px rgba(255, 140, 0, 0.3);
    }

    .emoji-besar {
      font-size: 3.8rem;
      filter: drop-shadow(0 6px 6px rgba(0,0,0,0.15));
      margin-bottom: 4px;
      line-height: 1;
    }

    .menu-nama {
      font-weight: 700;
      font-size: 1.4rem;
      background: #ffeac5;
      padding: 4px 18px;
      border-radius: 30px;
      color: #7b4a1e;
      margin: 6px 0 2px;
      letter-spacing: 0.4px;
    }

    .harga-tag {
      background: #fb8c1e;
      color: white;
      font-weight: 700;
      font-size: 1.2rem;
      padding: 6px 16px;
      border-radius: 24px;
      margin-top: 4px;
      box-shadow: 0 4px 8px rgba(251, 140, 30, 0.4);
      display: flex;
      align-items: center;
      gap: 4px;
    }

    /* Riwayat transaksi */
    .riwayat-section {
      background: #fef7e6;
      border-radius: 38px;
      padding: 16px 16px 12px;
      margin-top: 6px;
      border: 1px solid #fad48b;
    }

    .riwayat-title {
      font-weight: 700;
      font-size: 1.1rem;
      display: flex;
      align-items: center;
      gap: 6px;
      color: #b2591a;
      margin-bottom: 10px;
      justify-content: space-between;
    }

    .list-riwayat {
      max-height: 130px;
      overflow-y: auto;
      font-size: 0.9rem;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding-right: 4px;
    }

    .item-riwayat {
      background: white;
      border-radius: 24px;
      padding: 10px 14px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 3px 8px rgba(0,0,0,0.04);
      border-left: 6px solid #ffa726;
    }

    .item-riwayat .nama-jajan {
      font-weight: 600;
      color: #4d2e14;
    }

    .item-harga {
      background: #fbe9e7;
      padding: 4px 12px;
      border-radius: 16px;
      font-weight: 700;
      color: #bf360c;
    }

    .btn-reset {
      background: #fff0d4;
      border: 2px solid #ffb44b;
      color: #ad5f1a;
      font-weight: 700;
      padding: 10px 18px;
      border-radius: 30px;
      font-size: 0.9rem;
      cursor: pointer;
      transition: 0.2s;
      display: flex;
      align-items: center;
      gap: 6px;
      background: white;
      margin-left: 8px;
    }

    .btn-reset:active {
      background: #ffd58c;
      border-color: #e67e22;
    }

    .total-belanja {
      font-weight: 700;
      color: #b45f06;
      background: #ffeacc;
      padding: 4px 14px;
      border-radius: 20px;
    }

    .empty-message {
      color: #aa8e6c;
      font-style: italic;
      padding: 8px;
      text-align: center;
    }

    .row-header {
      display: flex;
      align-items: center;
      gap: 8px;
    }
  </style>
</head>
<body>
  <div class="app-container">
    <!-- HEADER -->
    <div class="header">
      <div class="app-name">🍡 Aditya</div>
      <div class="saldo-box">
        💰 <span id="saldoDisplay">50000</span>
      </div>
    </div>

    <!-- MENU JAJANAN (bisa diklik) -->
    <div class="menu-grid">
      <!-- Cilok -->
      <div class="menu-card" data-nama="Cilok" data-harga="2000">
        <div class="emoji-besar">🍢</div>
        <div class="menu-nama">Cilok</div>
        <div class="harga-tag">Rp2.000</div>
      </div>
      <!-- Bakso -->
      <div class="menu-card" data-nama="Bakso" data-harga="5000">
        <div class="emoji-besar">🍜</div>
        <div class="menu-nama">Bakso</div>
        <div class="harga-tag">Rp5.000</div>
      </div>
      <!-- Sosis -->
      <div class="menu-card" data-nama="Sosis" data-harga="4000">
        <div class="emoji-besar">🌭</div>
        <div class="menu-nama">Sosis</div>
        <div class="harga-tag">Rp4.000</div>
      </div>
      <!-- Esteh -->
      <div class="menu-card" data-nama="Esteh" data-harga="3000">
        <div class="emoji-besar">🧊🍵</div>
        <div class="menu-nama">Esteh</div>
        <div class="harga-tag">Rp3.000</div>
      </div>
    </div>

    <!-- RIWAYAT TRANSAKSI + RESET -->
    <div class="riwayat-section">
      <div class="riwayat-title">
        <div class="row-header">
          <span>📋 Riwayat Jajan</span>
          <span class="total-belanja" id="totalBelanja">Rp0</span>
        </div>
        <button class="btn-reset" id="btnReset">
          <span>🔄</span> Reset
        </button>
      </div>
      <div id="riwayatContainer" class="list-riwayat">
        <div class="empty-message">Belum ada jajan, yuk beli 🍢</div>
      </div>
    </div>
  </div>

  <script>
    (function() {
      // --- Data Aplikasi ---
      const NAMA_APP = "Aditya";
      
      // Saldo awal
      let saldo = 50000;
      
      // Array riwayat transaksi: { nama, harga }
      let riwayatTransaksi = [];

      // Elemen DOM
      const saldoDisplay = document.getElementById('saldoDisplay');
      const riwayatContainer = document.getElementById('riwayatContainer');
      const totalBelanjaEl = document.getElementById('totalBelanja');
      const btnReset = document.getElementById('btnReset');
      
      // Semua kartu menu
      const menuCards = document.querySelectorAll('.menu-card');

      // --- Fungsi memperbarui tampilan saldo ---
      function updateSaldoUI() {
        saldoDisplay.textContent = saldo.toLocaleString('id-ID');
      }

      // --- Hitung total pengeluaran dari riwayat ---
      function hitungTotalBelanja() {
        return riwayatTransaksi.reduce((total, item) => total + item.harga, 0);
      }

      // --- Render ulang daftar riwayat ---
      function renderRiwayat() {
        // Hapus isi container
        riwayatContainer.innerHTML = '';

        if (riwayatTransaksi.length === 0) {
          riwayatContainer.innerHTML = '<div class="empty-message">✨ Belum ada jajan, ayo beli cilok~</div>';
          totalBelanjaEl.textContent = 'Rp0';
          return;
        }

        // Tampilkan setiap transaksi
        riwayatTransaksi.forEach((item, index) => {
          const div = document.createElement('div');
          div.className = 'item-riwayat';
          div.innerHTML = `
            <span class="nama-jajan">${item.nama}</span>
            <span class="item-harga">- Rp${item.harga.toLocaleString('id-ID')}</span>
          `;
          riwayatContainer.appendChild(div);
        });

        // Update total belanja
        const total = hitungTotalBelanja();
        totalBelanjaEl.textContent = `Rp${total.toLocaleString('id-ID')}`;
      }

      // --- Proses pembelian (klik menu) ---
      function beliJajan(nama, harga) {
        // Cek kecukupan saldo
        if (saldo < harga) {
          alert(`😢 Saldo tidak cukup untuk membeli ${nama}.\nButuh Rp${harga.toLocaleString('id-ID')}, saldo kamu Rp${saldo.toLocaleString('id-ID')}.`);
          return;
        }

        // Kurangi saldo
        saldo -= harga;
        
        // Tambahkan ke riwayat
        riwayatTransaksi.push({ nama, harga });
        
        // Perbarui tampilan
        updateSaldoUI();
        renderRiwayat();

        // Efek kecil suara (opsional, hanya visual feedback)
        // Bisa tambahkan animasi kecil jika perlu
      }

      // --- Reset semua (kembali ke saldo 50000, hapus riwayat) ---
      function resetAplikasi() {
        // Konfirmasi ringan
        const konfirmasi = confirm('🔄 Reset saldo ke Rp50.000 dan hapus semua riwayat jajan?');
        if (!konfirmasi) return;

        // Kembalikan nilai awal
        saldo = 50000;
        riwayatTransaksi = [];
        
        updateSaldoUI();
        renderRiwayat();
        
        // Feedback kecil
        // Bisa alert kecil, tapi biar smooth saja
      }

      // --- Event Listener untuk setiap menu card ---
      menuCards.forEach(card => {
        card.addEventListener('click', function(e) {
          // Ambil data dari atribut
          const nama = this.getAttribute('data-nama');
          const hargaString = this.getAttribute('data-harga');
          const harga = parseInt(hargaString, 10);

          if (!nama || isNaN(harga)) {
            console.warn('Data menu tidak valid');
            return;
          }

          // Panggil fungsi beli
          beliJajan(nama, harga);
        });
      });

      // --- Event Listener tombol reset ---
      btnReset.addEventListener('click', resetAplikasi);

      // --- Inisialisasi tampilan awal ---
      updateSaldoUI();
      renderRiwayat();

      // (Opsional) Tampilkan nama aplikasi di console
      console.log(`🍡 Aplikasi ${NAMA_APP} siap! Jajan cilok, bakso, sosis, esteh.`);
    })();
  </script>
</body>
</html>
